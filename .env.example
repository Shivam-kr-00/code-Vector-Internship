# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Neon PostgreSQL)
# format: postgres://username:password@host:port/database?sslmode=require
DATABASE_URL=postgres://user:password@ep-host-name.region.aws.neon.tech/dbname?sslmode=require
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_TIMEOUT_MS=30000
